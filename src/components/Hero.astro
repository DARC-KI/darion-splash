---
---

<section class="hero" aria-labelledby="brand-mark">
  <p class="eyebrow">
    <span class="dot" aria-hidden="true"></span>
    Soft Launch am 20. Mai 2026
  </p>
  <h1 id="brand-mark" class="headline">
    Sichere KI für<br />
    <span class="accent">dein Unternehmen</span>
  </h1>
  <p class="lead">
    Neun Module von Finanzen bis KI-Telefonie in einer Plattform.
    Komplett auf Servern in Deutschland.
    <span class="emph">Kein Token verlässt deine Infrastruktur.</span>
  </p>
</section>

<style>
  .hero {
    text-align: center;
    padding: 0 1rem;
    max-width: 56rem;
    margin: 0 auto;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 1.5rem;
    padding: 0.4rem 0.9rem;
    border: 1px solid var(--border-soft);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.02);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--fg-muted);
    letter-spacing: 0.005em;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent);
  }

  .headline {
    margin: 0;
    font-size: clamp(2.5rem, 8vw, 5.5rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.02;
    color: var(--fg);
  }

  .accent {
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-deep) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
  }

  .lead {
    margin: 1.5rem auto 0;
    max-width: 38rem;
    font-size: clamp(1rem, 1.6vw, 1.1875rem);
    line-height: 1.55;
    color: var(--fg-muted);
    font-weight: 400;
  }

  .emph {
    color: var(--fg);
    font-weight: 500;
  }

  @media (max-width: 480px) {
    .eyebrow { font-size: 0.75rem; }
    .headline { letter-spacing: -0.025em; }
  }
</style>
