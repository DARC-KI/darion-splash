---
const year = new Date().getFullYear();
---

<footer class="footer">
  <nav class="footer-nav" aria-label="Rechtliches">
    <a href="https://landing.darion-ai.de/impressum" rel="noopener">Impressum</a>
    <span class="sep" aria-hidden="true">·</span>
    <a href="https://landing.darion-ai.de/datenschutz" rel="noopener">Datenschutz</a>
  </nav>
  <p class="copy">© {year} DARION</p>
</footer>

<style>
  .footer {
    text-align: center;
    padding: 1.5rem 1rem 2rem;
    color: var(--fg-subtle);
    font-size: 0.8125rem;
  }

  .footer-nav {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-nav a {
    color: var(--fg-muted);
    text-decoration: none;
    transition: color 120ms ease;
  }

  .footer-nav a:hover {
    color: var(--fg);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .sep {
    color: var(--border);
  }

  .copy {
    margin: 0.4rem 0 0;
    color: var(--fg-subtle);
  }
</style>
