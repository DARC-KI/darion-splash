---
const year = new Date().getFullYear();
---

<footer class="footer">
  <p class="brand-line">
    <span class="brand">DARION AI</span>
    <span class="sep" aria-hidden="true">·</span>
    <span class="tagline">KI-Plattform für den deutschen Mittelstand</span>
  </p>
  <nav class="footer-nav" aria-label="Rechtliches">
    <a href="https://landing.darion-ai.de/impressum" rel="noopener">Impressum</a>
    <span class="sep" aria-hidden="true">·</span>
    <a href="https://landing.darion-ai.de/datenschutz" rel="noopener">Datenschutz</a>
    <span class="sep" aria-hidden="true">·</span>
    <span class="copy">© {year} DARC Management UG</span>
  </nav>
</footer>

<style>
  .footer {
    text-align: center;
    padding: 2rem 1rem 2.5rem;
    color: var(--fg-subtle);
    font-size: 0.8125rem;
  }

  .brand-line {
    margin: 0 0 0.5rem;
    color: var(--fg-soft);
  }

  .brand {
    font-weight: 600;
    color: var(--fg-muted);
    letter-spacing: 0.005em;
  }

  .tagline {
    color: var(--fg-subtle);
  }

  .footer-nav {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .footer-nav a {
    color: var(--fg-soft);
    text-decoration: none;
    transition: color 120ms ease;
  }

  .footer-nav a:hover {
    color: var(--fg);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .sep {
    color: var(--border-soft);
  }

  .copy {
    color: var(--fg-subtle);
  }
</style>
