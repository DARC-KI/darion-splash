---
const pills = [
  "Hetzner, Frankfurt",
  "DSGVO, NIS2, AI Act",
  "Open Source Modelle, kein US-Cloud",
];
---

<section class="trust" aria-label="Trust-Anker">
  <ul class="pill-list">
    {pills.map((label) => (
      <li class="pill">
        <span class="check" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </span>
        <span class="label">{label}</span>
      </li>
    ))}
  </ul>
</section>

<style>
  .trust {
    margin: 0 auto;
    padding: 0 1rem;
    width: 100%;
    max-width: 48rem;
  }

  .pill-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 1rem 0.55rem 0.7rem;
    border: 1px solid var(--border-soft);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.025);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--fg-muted);
    letter-spacing: -0.005em;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: rgba(113, 112, 255, 0.15);
    color: var(--accent);
    flex-shrink: 0;
  }

  .label {
    line-height: 1.2;
  }

  @media (max-width: 600px) {
    .pill-list {
      flex-direction: column;
      align-items: stretch;
    }
    .pill {
      justify-content: center;
    }
  }
</style>
