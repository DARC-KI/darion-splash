---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "DARION — Die KI-native Plattform für KMU-Beratung & Service",
  description = "DARION ist eine mandantensichere, EU-gehostete und DSGVO-konforme KI-Plattform für Beratungs- und Serviceunternehmen.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL("/og.svg", Astro.site).toString();

const plausibleHost = import.meta.env.PUBLIC_PLAUSIBLE_HOST;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="dark light" />
    <meta name="theme-color" content="#0a0a0a" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="DARION" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="de_DE" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="robots" content="index,follow" />

    {plausibleHost && (
      <script
        is:inline
        defer
        data-domain="darion.ai"
        src={`https://${plausibleHost}/js/script.outbound-links.js`}
      />
    )}

    <style is:global>
      :root {
        --bg: #0a0a0a;
        --bg-elev: #111114;
        --fg: #f5f5f4;
        --fg-muted: #a3a3a3;
        --fg-subtle: #525252;
        --accent: #d4d4d4;
        --border: #262626;
        --radius: 14px;
        --font-sans: "Geist", "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI",
          Roboto, "Helvetica Neue", Arial, sans-serif;
      }

      *, *::before, *::after { box-sizing: border-box; }

      html, body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--fg);
        font-family: var(--font-sans);
        font-size: 16px;
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
      }

      body {
        min-height: 100vh;
        min-height: 100dvh;
        background:
          radial-gradient(ellipse 80% 60% at 50% 0%, rgba(255, 255, 255, 0.04), transparent 70%),
          radial-gradient(ellipse 60% 40% at 50% 100%, rgba(255, 255, 255, 0.02), transparent 70%),
          var(--bg);
        display: flex;
        flex-direction: column;
      }

      a { color: inherit; }
      a:focus-visible, button:focus-visible {
        outline: 2px solid var(--fg);
        outline-offset: 3px;
        border-radius: 4px;
      }

      ::selection { background: var(--fg); color: var(--bg); }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
