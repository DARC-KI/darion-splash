---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "DARION AI: Sichere KI-Plattform für den deutschen Mittelstand",
  description = "Neun Module von Finanzen bis KI-Telefonie in einer Plattform. Komplett auf Servern in Deutschland gehostet. DSGVO, NIS2 und EU AI Act ready. Launch 20. Mai 2026.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL("/og.svg", Astro.site).toString();

const plausibleHost = import.meta.env.PUBLIC_PLAUSIBLE_HOST;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#08090a" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="DARION AI" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="de_DE" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="robots" content="index,follow" />

    {plausibleHost && (
      <script
        is:inline
        defer
        data-domain="darion.ai"
        src={`https://${plausibleHost}/js/script.outbound-links.js`}
      />
    )}

    <style is:global>
      :root {
        /* Brand-Farben aus landing.darion-ai.de */
        --bg: #08090a;
        --fg: #f7f8f8;
        --fg-muted: #d0d6e0;
        --fg-soft: #8a8f98;
        --fg-subtle: #62666d;
        --accent: #7170ff;
        --accent-deep: #5e6ad2;
        --border: #1a1b1e;
        --border-soft: #26282d;
        --radius: 14px;
        --font-sans: "Inter", "Geist", -apple-system, BlinkMacSystemFont, "Segoe UI",
          Roboto, "Helvetica Neue", Arial, sans-serif;
      }

      *, *::before, *::after { box-sizing: border-box; }

      html, body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--fg);
        font-family: var(--font-sans);
        font-size: 16px;
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
      }

      body {
        min-height: 100vh;
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        position: relative;
        overflow-x: hidden;
      }

      /* Hero-Glow analog landing.darion-ai.de (radial purple/indigo) */
      body::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(
          ellipse 70% 55% at 50% 30%,
          rgba(94, 106, 210, 0.22) 0%,
          rgba(113, 112, 255, 0.12) 35%,
          transparent 65%
        );
        filter: blur(40px);
        pointer-events: none;
        z-index: 0;
      }

      body > * {
        position: relative;
        z-index: 1;
      }

      a { color: inherit; }
      a:focus-visible, button:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 3px;
        border-radius: 6px;
      }

      ::selection { background: var(--accent); color: var(--fg); }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
